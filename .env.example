APP_ENV=development
DATABASE_URL=postgresql+psycopg://jarvis:${POSTGRES_PASSWORD}@postgres:5432/jarvis
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Set a strong random secret here. The app will refuse to start in non-development
# environments if this is empty. Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
JARVIS_API_KEY=
# Required by docker-compose. Change before storing personal data.
POSTGRES_PASSWORD=jarvis
